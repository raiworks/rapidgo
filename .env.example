# =============================================================================
# RapidGo Framework — Environment Configuration
# =============================================================================
# Copy this file to .env before running the application:
#   cp .env.example .env
# Then update the values with your actual credentials.
# The .env file is gitignored — never commit real secrets.
# For additional local overrides, create .env.local (also gitignored).
# =============================================================================

# --- Application ---
APP_NAME=RapidGo
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_URL=http://localhost:8080

# --- Service Mode ---
RAPIDGO_MODE=all
# WEB_PORT=8080
# API_PORT=8080
# WS_PORT=8080

# --- Database ---
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rapidgo_dev
DB_USER=postgres
DB_PASSWORD=secret
DB_SSL_MODE=disable
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=10
# DB_CONN_MAX_LIFETIME=5
# DB_CONN_MAX_IDLE_TIME=3

# --- Session ---
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECRET=change-me-to-a-random-string

# --- Cache ---
CACHE_DRIVER=memory
CACHE_PREFIX=rapidgo_

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Queue ---
QUEUE_DRIVER=database
QUEUE_DEFAULT=default
QUEUE_TABLE=jobs
QUEUE_FAILED_TABLE=failed_jobs
QUEUE_MAX_ATTEMPTS=3
QUEUE_RETRY_DELAY=30
QUEUE_TIMEOUT=60
QUEUE_POLL_INTERVAL=3

# --- JWT ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes
JWT_EXPIRY=3600

# --- Mail ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME=RapidGo

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout

# --- Storage ---
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_KEY=
S3_SECRET=

# --- Server ---
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_IDLE_TIMEOUT=120
